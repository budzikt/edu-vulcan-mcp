{
  "name": "edu-vulcan-mcp",
  "version": "1.0.1",
  "description": "MCP server for the Polish EduVulcan student education portal — access grades, messages, and assignments",
  "userConfig": {
    "alias": {
      "type": "string",
      "title": "EduVulcan Alias",
      "description": "Your EduVulcan login alias (the short login identifier)",
      "sensitive": false
    },
    "password": {
      "type": "string",
      "title": "EduVulcan Password",
      "description": "Your EduVulcan account password",
      "sensitive": false
    }
  },
  "mcpServers": {
    "edu-vulcan-mcp": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/bundle/index.js"],
      "env": {
        "VULCAN_ALIAS": "${user_config.alias}",
        "VULCAN_PASSWORD": "${user_config.password}"
      }
    }
  }
}
